# ============================================
# Application Configuration
# ============================================
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# ============================================
# Database Connection
# ============================================
# Production (Supabase): postgresql://user:password@aws-host.pooler.supabase.com:6543/postgres
DATABASE_URL=sqlite:///./smartcontainer.db

# ============================================
# JWT Authentication & Security
# ============================================
SECRET_KEY=generate_a_secure_random_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ============================================
# Machine Learning Ensemble Weights
# ============================================
XGB_WEIGHT=0.40
LGBM_WEIGHT=0.35
ANOMALY_WEIGHT=0.25

# ============================================
# Roboflow Image Analysis (Optional)
# ============================================
ROBOFLOW_API_KEY=your_roboflow_private_api_key_here
ROBOFLOW_API_URL=https://serverless.roboflow.com
