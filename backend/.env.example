# SmartContainer Risk Engine - Backend Configuration
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control!

# ============================================
# APPLICATION CONFIGURATION
# ============================================
APP_NAME=SmartContainer Risk Engine API
APP_VERSION=1.0.0
ENVIRONMENT=production

# ============================================
# JWT & SECURITY
# ============================================
# ⚠️ CRITICAL: Change this to a strong random secret in production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your_super_secret_key_change_in_production

# JWT Algorithm (HS256, HS512, RS256, etc.)
ALGORITHM=HS256

# Token expiration time in minutes (default: 10080 = 1 week)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ============================================
# DATABASE
# ============================================
# ⚠️  IMPORTANT: SQLite does NOT work on Render (ephemeral filesystem)
# Use Supabase PostgreSQL for production instead!

# Local Development (SQLite - file-based):
DATABASE_URL=sqlite:///./smartcontainer.db

# Production with Supabase (RECOMMENDED):
# 1. Create free Supabase project: https://supabase.com
# 2. Get connection string from: Project Settings → Database → Connection String (URI)
# 3. Replace YOUR_PASSWORD with your database password
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Example Supabase URL (replace with your project details):
# DATABASE_URL=postgresql://postgres:abc123xyz@db.abc123xyz.supabase.co:5432/postgres

# Alternative: Railway PostgreSQL
# DATABASE_URL=postgresql://user:password@your-railway-db.railway.app:5432/railway

# Alternative: Standard PostgreSQL (localhost)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/smartcontainer

# ============================================
# LOGGING
# ============================================
# Log levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================
# ROBOFLOW - IMAGE ANALYSIS API
# ============================================
# Get your API key from: https://roboflow.com
ROBOFLOW_API_KEY=your_roboflow_api_key_here
ROBOFLOW_API_URL=https://serverless.roboflow.com

# ============================================
# ML MODEL WEIGHTS (Ensemble Configuration)
# ============================================
# These weights control how much each model contributes to final risk score
# They must sum to 1.0 for proper scoring (0.40 + 0.35 + 0.25 = 1.0)
XGB_WEIGHT=0.40
LGBM_WEIGHT=0.35
ANOMALY_WEIGHT=0.25

# ============================================
# CORS CONFIGURATION (Frontend URLs)
# ============================================
# Comma-separated list of allowed frontend origins
# Examples: http://localhost:3000,https://dashboard.example.com,https://app.render.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ============================================
# OPTIONAL: Advanced Configuration
# ============================================
# Database pool size (for PostgreSQL)
# DATABASE_POOL_SIZE=20

# Max upload file size in MB
# MAX_UPLOAD_SIZE_MB=100

# API rate limiting (requests per minute)
# RATE_LIMIT_RPM=1000
